{
  "version": 2,
  "functions": {
    "api/generate-article.js": {
      "maxDuration": 30
    },
    "api/get-amazon-products.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
